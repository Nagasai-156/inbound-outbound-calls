# Supabase Postgres — Prisma connection strings.
# DATABASE_URL  = pooled (PgBouncer, port 6543, ?pgbouncer=true)
# DIRECT_URL    = direct (port 5432) — used for `prisma migrate`
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase project — Auth + Realtime (browser-safe anon key)
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Python control API (LiveKit token / outbound dial / content regen)
PYTHON_API_URL="http://localhost:8000"

# Shared secret for the Python control API. MUST match CONTROL_API_KEY
# in the root .env. Sent as the X-API-Key header on every proxy call so
# the outbound dialer / campaign runner can't be hit by anyone else.
CONTROL_API_KEY=
