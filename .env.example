# ─── LiveKit Cloud ─────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Sarvam (STT + TTS) ────────────────────────────────────────
SARVAM_API_KEY=

# ─── OpenAI (LLM + KB vector store / file_search) ──────────────
OPENAI_API_KEY=
# Set after running scripts/ingest_kb.py
OPENAI_KB_VECTOR_STORE_ID=

# ─── Redis (semantic cache + per-call structured state) ────────
REDIS_URL=redis://localhost:6379/0

# ─── Supabase Postgres (system of record; Prisma owns schema) ──
# Python agent connects with asyncpg using SUPABASE_DB_URL (use the
# Supabase "Session"/direct connection string, sslmode=require).
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── Vobiz SIP trunk (inbound DID + outbound auth) ─────────────
VOBIZ_SIP_HOST=
VOBIZ_SIP_USERNAME=
VOBIZ_SIP_PASSWORD=
VOBIZ_INBOUND_DID=
# Printed by `python -m src.telephony.sip_setup`
OUTBOUND_TRUNK_ID=

# ─── Agent ─────────────────────────────────────────────────────
AGENT_NAME=ai-voice-agent

# ─── Tuning (optional; sensible defaults in config.py) ─────────
# LLM_MODEL=gpt-4o-mini
# STT_MODEL=saaras:v3
# TTS_MODEL=bulbul:v2
# LOG_LEVEL=INFO

# ─── Dashboard (Next.js) ────────────────────────────────────────
# Same Postgres as the Python agent. DIRECT_URL is REQUIRED for
# `prisma migrate` / `prisma db push` (Supabase pooler does not
# support all DDL features).
DATABASE_URL=${SUPABASE_DB_URL}
DIRECT_URL=${SUPABASE_DB_URL}
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Worker supervision (scripts/watchdog.py) ───────────────────
# Port the watchdog probes for HARD-DOWN signal; defaults to 8081.
WORKER_HEALTH_PORT=8081

# ─── Control API auth (REQUIRED in production) ─────────────────
# Shared secret the Next.js dashboard sends to the Python control API
# (outbound dialer / campaigns / LiveKit tokens). MUST be set to the
# SAME value here and in dashboard/.env (CONTROL_API_KEY). If empty the
# control API is UNAUTHENTICATED (anyone reaching :8000 can place calls).
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
CONTROL_API_KEY=

# ─── Azure OpenAI (India region — low-latency LLM, optional) ───
# Same gpt-4o-mini model hosted in an India region (Central India) so
# LLM first-token drops from ~1s (OpenAI US) to ~300ms, with ZERO
# quality change. ENDPOINT must be the full /openai/v1 base. To use it,
# set the LLM model (env DEFAULT_LLM_MODEL or dashboard) to
# "azure/<deployment-name>", e.g. "azure/gpt-4o-mini".
# NOTE: deploy a STANDARD model (gpt-4o-mini) — NOT an "o" reasoning
# model (o4-mini etc.), which are slow for voice (~2.7s first token).
AZURE_OPENAI_ENDPOINT=https://diigoo-openai-india.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=
